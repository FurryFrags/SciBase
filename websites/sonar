<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sonar Distance Calculator</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body {
            width: 100%;
            height: 100%;
            background: #0a0a12;
            font-family: 'Courier New', monospace;
            overflow: hidden; /* Prevent scrollbars */
            color: #ccc;
        }
        #canvas {
            display: block; /* Remove extra pixel at bottom */
            width: 100vw;
            height: 100vh;
            image-rendering: pixelated; 
        }
        #controls {
            position: absolute; /* Position over canvas */
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(10, 20, 30, 0.85);
            padding: 15px 25px;
            border-radius: 8px;
            border: 1px solid #1a4a5a;
            display: flex;
            gap: 30px;
            align-items: center;
            flex-wrap: wrap;
            justify-content: center;
            z-index: 10;
        }
        .control-group { display: flex; flex-direction: column; gap: 5px; align-items: center; }
        .control-group label { color: #5af; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }
        input[type="range"] {
            width: 120px; height: 6px; -webkit-appearance: none; background: #1a2a3a; border-radius: 3px;
        }
        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none; width: 14px; height: 14px;
            background: linear-gradient(135deg, #0ff, #08f); border-radius: 50%; cursor: pointer;
        }
        select {
            background: #1a2a3a; color: #0ff; border: 1px solid #0ff;
            padding: 4px; border-radius: 4px; font-family: inherit; cursor: pointer;
        }
        .value-display { color: #0ff; font-size: 12px; text-shadow: 0 0 10px #0af; }
        #info-panel {
            position: absolute; top: 20px; right: 20px;
            background: rgba(10, 20, 30, 0.9); padding: 15px; border-radius: 8px;
            border: 1px solid #1a4a5a; color: #8cf; font-size: 12px; line-height: 1.8; min-width: 160px;
            z-index: 10;
        }
        #info-panel h3 { color: #0ff; margin-bottom: 10px; font-size: 14px; border-bottom: 1px solid #1a4a5a; padding-bottom: 5px; }
        .data-row { display: flex; justify-content: space-between; }
        .data-label { color: #6af; }
        .data-value { color: #0f8; font-weight: bold; }
        h1 {
            position: absolute;
            top: 15px;
            left: 20px;
            color: #0ff;
            font-size: 20px;
            text-shadow: 0 0 20px #0af;
            letter-spacing: 3px;
            font-weight: normal;
            z-index: 10;
        }
    </style>
</head>
<body>
    <h1>SONAR DEPTH SIMULATOR</h1>
    <canvas id="canvas"></canvas>
    
    <div id="controls">
        <div class="control-group">
            <label>Mode</label>
            <select id="viewMode">
                <option value="ray">Ray Mode</option>
                <option value="particle">Particle Mode</option>
            </select>
        </div>
        <div class="control-group">
            <label>Freq (kHz)</label>
            <input type="range" id="frequency" min="0.1" max="5" value="1.0" step="0.1">
            <div class="value-display" id="freq-value">1.0 kHz</div>
        </div>
        <div class="control-group">
            <label>Rate (Hz)</label>
            <input type="range" id="pulseRate" min="0.1" max="3" value="1.0" step="0.1">
            <div class="value-display" id="pulse-value">1.0 Hz</div>
        </div>
        <div class="control-group">
            <label>Beam (deg)</label>
            <input type="range" id="beamWidth" min="5" max="60" value="30" step="1">
            <div class="value-display" id="beam-value">30 deg</div>
        </div>
    </div>

    <div id="info-panel">
        <h3>SENSOR DATA</h3>
        <div class="data-row"><span class="data-label">Depth:</span><span class="data-value" id="depth-display">-- m</span></div>
        <div class="data-row"><span class="data-label">Range:</span><span class="data-value" id="range-display">-- m</span></div>
        <div class="data-row"><span class="data-label">Wavelength:</span><span class="data-value" id="wavelength-display">-- m</span></div>
        <div class="data-row"><span class="data-label">Resolution:</span><span class="data-value" id="resolution-display">-- m</span></div>
    </div>

    <script>
        const canvas = document.getElementById('canvas');
        const ctx = canvas.getContext('2d', { alpha: false });
        
        // --- Configuration ---
        const SOUND_SPEED = 1500;
        const RAY_COUNT = 24; 
        const MAX_BOUNCES = 5;
        const MAX_PULSES = 20;
        const SIM_SPEED = 30; 

        // --- Dynamic State ---
        let WIDTH, HEIGHT;
        let WATER_SURFACE;
        
        let seafloorY, seafloorNX, seafloorNY;
        let discoveredMap; 
        
        const pulsePool = new Array(MAX_PULSES);

        const state = {
            ship: { x: 0, y: 0, width: 60, height: 25, speed: 3, vspeed: 2 },
            mouse: { x: 0, y: 0 },
            keys: {},
            frequency: 1.0,
            pulseRate: 1.0,
            beamWidth: 30,
            lastPulseTime: 0,
            mode: 'ray',
            bubble: {
                text: "",
                visible: false
            },
            pendingUpdate: null
        };

        // --- Layers ---
        let bgCanvas, bgCtx, mapCanvas, mapCtx;

        // --- Initialization System ---
        
        function initCanvas() {
            WIDTH = window.innerWidth;
            HEIGHT = window.innerHeight;
            canvas.width = WIDTH;
            canvas.height = HEIGHT;

            WATER_SURFACE = HEIGHT * 0.12; // 12% from top

            // Re-init layers
            bgCanvas = document.createElement('canvas');
            bgCanvas.width = WIDTH;
            bgCanvas.height = HEIGHT;
            bgCtx = bgCanvas.getContext('2d');

            mapCanvas = document.createElement('canvas');
            mapCanvas.width = WIDTH;
            mapCanvas.height = HEIGHT;
            mapCtx = mapCanvas.getContext('2d');

            // Re-init Arrays
            seafloorY = new Float32Array(WIDTH);
            seafloorNX = new Float32Array(WIDTH);
            seafloorNY = new Float32Array(WIDTH);
            discoveredMap = new Uint8Array(WIDTH * HEIGHT);

            // Reset Ship Pos
            state.ship.x = WIDTH / 2;
            state.ship.y = WATER_SURFACE + 40;
            
            initPools(); 
        }

        function initTerrain() {
            let baseDepth = HEIGHT * 0.75; // 75% down screen
            for (let x = 0; x < WIDTH; x++) {
                let depth = baseDepth;
                depth += Math.sin(x * 0.01) * 40;
                depth += Math.sin(x * 0.03 + 1) * 25;
                depth += Math.sin(x * 0.007) * 60;
                if (Math.random() < 0.003) depth -= Math.random() * 50 + 20;
                seafloorY[x] = Math.max(WATER_SURFACE + 100, depth);
            }
            for (let i = 1; i < WIDTH - 1; i++)
                seafloorY[i] = (seafloorY[i-1] + seafloorY[i] + seafloorY[i+1]) / 3;

            for (let x = 1; x < WIDTH - 1; x++) {
                let dx = 2;
                let dy = seafloorY[x+1] - seafloorY[x-1];
                let len = Math.sqrt(dx*dx + dy*dy);
                let nx = -dy / len;
                let ny = dx / len;
                seafloorNX[x] = nx;
                seafloorNY[x] = ny;
            }
        }

        function initBackground() {
            // Sky
            const skyGrad = bgCtx.createLinearGradient(0, 0, 0, WATER_SURFACE);
            skyGrad.addColorStop(0, '#1a2a3a'); skyGrad.addColorStop(1, '#2a4a5a');
            bgCtx.fillStyle = skyGrad;
            bgCtx.fillRect(0, 0, WIDTH, WATER_SURFACE);

            // Water
            const waterGrad = bgCtx.createLinearGradient(0, WATER_SURFACE, 0, HEIGHT);
            waterGrad.addColorStop(0, '#0a2a3a'); waterGrad.addColorStop(0.5, '#051525'); waterGrad.addColorStop(1, '#010810');
            bgCtx.fillStyle = waterGrad;
            bgCtx.fillRect(0, WATER_SURFACE, WIDTH, HEIGHT - WATER_SURFACE);

            // Grid
            bgCtx.strokeStyle = 'rgba(100, 150, 200, 0.1)';
            bgCtx.lineWidth = 1;
            bgCtx.beginPath();
            for (let d = 50; d < HEIGHT; d += 50) {
                const y = WATER_SURFACE + d;
                if (y < HEIGHT) { bgCtx.moveTo(0, y); bgCtx.lineTo(WIDTH, y); }
            }
            bgCtx.stroke();
            
            bgCtx.fillStyle = '#5af'; bgCtx.font = '10px Courier New';
            bgCtx.fillText('SURFACE', 5, WATER_SURFACE - 5);
            for (let d = 50; d < HEIGHT; d += 50) bgCtx.fillText(`${d}m`, 5, WATER_SURFACE + d + 4);

            bgCtx.fillStyle = '#1a0a05';
            bgCtx.beginPath();
            bgCtx.moveTo(0, HEIGHT);
            for (let x = 0; x < WIDTH; x++) bgCtx.lineTo(x, seafloorY[x]);
            bgCtx.lineTo(WIDTH, HEIGHT);
            bgCtx.closePath();
            bgCtx.fill();
        }

        function initPools() {
            for(let i=0; i<MAX_PULSES; i++) {
                pulsePool[i] = {
                    active: false, alpha: 1, maxDist: 0, 
                    speed: SIM_SPEED, 
                    originX:0, originY:0,
                    rays: new Array(RAY_COUNT)
                };
                for(let j=0; j<RAY_COUNT; j++) {
                    pulsePool[i].rays[j] = {
                        x:0, y:0, vx:0, vy:0, dist:0, bounces:0, alive:false,
                        hx: new Float32Array(MAX_BOUNCES+1), 
                        hy: new Float32Array(MAX_BOUNCES+1),
                        hCount: 0
                    };
                }
            }
        }

        // First Run
        initCanvas();
        initTerrain();
        initBackground();

        // Resize Listener
        window.addEventListener('resize', () => {
            initCanvas();
            initTerrain();
            initBackground();
        });


        // --- Logic ---

        function spawnPulse(x, y, angle, frequency, beamWidth) {
            const p = pulsePool.find(p => !p.active);
            if(!p) return;

            p.active = true;
            p.originX = x; p.originY = y;
            p.alpha = 1;
            const baseRange = 150;
            p.maxDist = Math.min(WIDTH * 2.5, baseRange + 800 * (1/frequency));
            
            const halfBeam = (beamWidth * Math.PI / 180) / 2;
            const rays = p.rays;
            for(let i=0; i<RAY_COUNT; i++) {
                const r = rays[i];
                const a = angle - halfBeam + (halfBeam * 2 * i / (RAY_COUNT - 1));
                
                r.x = x; r.y = y;
                r.vx = Math.cos(a); r.vy = Math.sin(a);
                r.dist = 0; r.bounces = 0; r.alive = true;
                r.hx[0] = x; r.hy[0] = y;
                r.hCount = 1;
            }
        }

        const reflect = (vx, vy, nx, ny) => {
            const dot2 = 2 * (vx * nx + vy * ny);
            return { rx: vx - dot2 * nx, ry: vy - dot2 * ny };
        };

        function updatePulses(timestamp) {
            if (state.pendingUpdate && timestamp >= state.pendingUpdate.time) {
                state.bubble.text = state.pendingUpdate.text;
                state.bubble.visible = true;
                state.pendingUpdate = null;
            }

            for(let i=0; i<MAX_PULSES; i++) {
                const p = pulsePool[i];
                if(!p.active) continue;

                let aliveRays = 0;
                const rays = p.rays;
                const speed = p.speed;

                for(let j=0; j<RAY_COUNT; j++) {
                    const r = rays[j];
                    if(!r.alive) continue;

                    r.x += r.vx * speed;
                    r.y += r.vy * speed;
                    r.dist += speed;

                    if (r.dist > p.maxDist) { r.alive = false; continue; }
                    
                    aliveRays++;
                    let hit = false;

                    if (r.y < WATER_SURFACE) {
                        r.vy = Math.abs(r.vy);
                        r.y = WATER_SURFACE;
                        r.bounces++;
                        hit = true;
                        r.hx[r.hCount] = r.x;
                        r.hy[r.hCount] = r.y;
                        r.hCount++;

                        const centerIndex = (RAY_COUNT / 2) | 0;
                        if (j === centerIndex) {
                            const distanceSlant = r.dist;
                            const returnFrames = distanceSlant / speed;
                            const returnMs = returnFrames * (1000/60);
                            
                            state.pendingUpdate = {
                                time: timestamp + returnMs,
                                text: `Hit: SURFACE\nRange: ${distanceSlant.toFixed(0)}m\nDepth: 0m`
                            };
                        }
                    }

                    const idx = r.x | 0; 
                    if (idx > 0 && idx < WIDTH) {
                        const floorY = seafloorY[idx];
                        if (r.y >= floorY) {
                            const nx = seafloorNX[idx];
                            const ny = seafloorNY[idx];
                            
                            const ref = reflect(r.vx, r.vy, nx, ny);
                            r.vx = ref.rx; r.vy = ref.ry;
                            
                            r.y = floorY - 1;
                            r.bounces++;
                            hit = true;
                            
                            r.hx[r.hCount] = r.x;
                            r.hy[r.hCount] = r.y;
                            r.hCount++;

                            const mapIdx = idx + (floorY | 0) * WIDTH;
                            if(!discoveredMap[mapIdx]) {
                                discoveredMap[mapIdx] = 1;
                                mapCtx.fillStyle = '#0f8';
                                mapCtx.fillRect(idx, floorY, 2, 2);
                            }

                            const centerIndex = (RAY_COUNT / 2) | 0;
                            if (j === centerIndex) {
                                const distanceSlant = r.dist;
                                const depthVertical = floorY - WATER_SURFACE;
                                const returnFrames = distanceSlant / speed;
                                const returnMs = returnFrames * (1000/60); 
                                
                                state.pendingUpdate = {
                                    time: timestamp + returnMs,
                                    text: `Hit: SEAFLOOR\nRange: ${distanceSlant.toFixed(0)}m\nDepth: ${depthVertical.toFixed(0)}m`
                                };
                            }
                        }
                    }

                    if (r.x < 0 || r.x >= WIDTH) { r.alive = false; continue; }
                    if (hit && r.bounces > MAX_BOUNCES) r.alive = false;
                }

                if(aliveRays === 0) p.active = false;
            }
        }

        // --- Render ---

        function drawPulses(ctx) {
            const mode = state.mode;
            
            if (mode === 'ray') {
                ctx.strokeStyle = '#0ff';
                ctx.lineWidth = 1;
                ctx.globalAlpha = 0.6;
                ctx.beginPath();
                
                for(let i=0; i<MAX_PULSES; i++) {
                    const p = pulsePool[i];
                    if(!p.active) continue;
                    for(let j=0; j<RAY_COUNT; j++) {
                        const r = p.rays[j];
                        if(r.hCount === 1) {
                             ctx.moveTo(r.hx[0], r.hy[0]);
                             if(r.alive) ctx.lineTo(r.x, r.y);
                        } else {
                            ctx.moveTo(r.hx[0], r.hy[0]);
                            ctx.lineTo(r.hx[1], r.hy[1]);
                        }
                    }
                }
                ctx.stroke();

                ctx.strokeStyle = '#f55';
                ctx.globalAlpha = 0.4;
                ctx.beginPath();
                
                for(let i=0; i<MAX_PULSES; i++) {
                    const p = pulsePool[i];
                    if(!p.active) continue;
                    for(let j=0; j<RAY_COUNT; j++) {
                        const r = p.rays[j];
                        if(r.hCount > 1) {
                            ctx.moveTo(r.hx[1], r.hy[1]);
                            for(let k=2; k<r.hCount; k++) {
                                ctx.lineTo(r.hx[k], r.hy[k]);
                            }
                            if(r.alive) ctx.lineTo(r.x, r.y);
                        }
                    }
                }
                ctx.stroke();

            } else {
                ctx.globalAlpha = 1;
                for(let i=0; i<MAX_PULSES; i++) {
                    const p = pulsePool[i];
                    if(!p.active) continue;
                    
                    for(let j=0; j<RAY_COUNT; j++) {
                        const r = p.rays[j];
                        if(!r.alive) continue;

                        ctx.fillStyle = r.bounces > 0 ? '#f55' : '#0ff';
                        ctx.shadowColor = r.bounces > 0 ? '#f00' : '#0ff';
                        ctx.shadowBlur = 10;
                        
                        ctx.beginPath();
                        ctx.arc(r.x, r.y, 3, 0, Math.PI*2);
                        ctx.fill();
                    }
                }
                ctx.shadowBlur = 0;
            }
        }

        function drawShip(ctx) {
            const s = state.ship;
            ctx.save(); ctx.translate(s.x, s.y);
            
            ctx.fillStyle = '#4a5568'; ctx.strokeStyle = '#718096'; ctx.lineWidth = 2;
            ctx.beginPath(); ctx.ellipse(0, 0, s.width/2, s.height/2, 0, 0, Math.PI * 2);
            ctx.fill(); ctx.stroke();
            
            ctx.fillStyle = '#2d3748'; ctx.fillRect(-8, -s.height/2 - 10, 16, 12); ctx.strokeRect(-8, -s.height/2 - 10, 16, 12);
            
            const angle = Math.atan2(state.mouse.y - s.y, state.mouse.x - s.x);
            ctx.strokeStyle = '#0ff'; ctx.lineWidth = 2;
            ctx.beginPath(); ctx.moveTo(0, 0); ctx.lineTo(Math.cos(angle) * 40, Math.sin(angle) * 40); ctx.stroke();
            
            if (state.bubble.visible) {
                ctx.font = 'bold 14px Courier New';
                const lines = state.bubble.text.split('\n');
                const padding = 10;
                let maxW = 0;
                lines.forEach(l => { 
                    const w = ctx.measureText(l).width;
                    if(w > maxW) maxW = w;
                });
                const bh = lines.length * 18 + padding * 2;
                const bw = maxW + padding * 2;
                const bx = -bw/2;
                const by = -s.height/2 - 15 - bh - 10; 

                ctx.fillStyle = 'rgba(255, 255, 255, 0.95)';
                ctx.strokeStyle = '#000';
                ctx.lineWidth = 1;
                
                ctx.beginPath();
                ctx.moveTo(bx + 5, by);
                ctx.lineTo(bx + bw - 5, by);
                ctx.quadraticCurveTo(bx + bw, by, bx + bw, by + 5);
                ctx.lineTo(bx + bw, by + bh - 5);
                ctx.quadraticCurveTo(bx + bw, by + bh, bx + bw - 5, by + bh);
                ctx.lineTo(bx + 5, by + bh);
                ctx.quadraticCurveTo(bx, by + bh, bx, by + bh - 5);
                ctx.lineTo(bx, by + 5);
                ctx.quadraticCurveTo(bx, by, bx + 5, by);
                ctx.closePath();
                ctx.fill();
                ctx.stroke();

                ctx.beginPath();
                ctx.moveTo(0, by + bh);
                ctx.lineTo(-6, by + bh + 12);
                ctx.lineTo(6, by + bh + 12);
                ctx.closePath();
                ctx.fill();
                ctx.stroke();

                ctx.fillStyle = '#000';
                ctx.textAlign = 'left';
                ctx.textBaseline = 'top';
                lines.forEach((l, idx) => {
                    ctx.fillText(l, bx + padding, by + padding + idx * 18);
                });
            }

            ctx.restore();
        }

        // --- Main Loop ---

        document.addEventListener('keydown', e => state.keys[e.key.toLowerCase()] = true);
        document.addEventListener('keyup', e => state.keys[e.key.toLowerCase()] = false);
        
        window.addEventListener('mousemove', e => {
            state.mouse.x = e.clientX;
            state.mouse.y = e.clientY;
        });
        
        document.getElementById('frequency').addEventListener('input', e => state.frequency = parseFloat(e.target.value));
        document.getElementById('pulseRate').addEventListener('input', e => state.pulseRate = parseFloat(e.target.value));
        document.getElementById('beamWidth').addEventListener('input', e => state.beamWidth = parseFloat(e.target.value));
        document.getElementById('viewMode').addEventListener('change', e => state.mode = e.target.value);
        
        canvas.addEventListener('click', () => {
             const angle = Math.atan2(state.mouse.y - state.ship.y, state.mouse.x - state.ship.x);
             spawnPulse(state.ship.x, state.ship.y, angle, state.frequency, state.beamWidth);
        });

        function updateInfo() {
            const wl = (SOUND_SPEED / (state.frequency * 1000)).toFixed(2);
            const range = (150 + 800 * (1/state.frequency)).toFixed(0);
            document.getElementById('freq-value').textContent = `${state.frequency.toFixed(1)} kHz`;
            document.getElementById('pulse-value').textContent = `${state.pulseRate.toFixed(1)} Hz`;
            document.getElementById('beam-value').textContent = `${state.beamWidth} deg`;
            document.getElementById('depth-display').textContent = `${(state.ship.y - WATER_SURFACE).toFixed(0)} m`;
            document.getElementById('range-display').textContent = `${range} m`;
            document.getElementById('wavelength-display').textContent = `${wl} m`;
            document.getElementById('resolution-display').textContent = `${(wl/2).toFixed(2)} m`;
        }

        function gameLoop(timestamp) {
            // Input
            if (state.keys['a']) state.ship.x = Math.max(30, state.ship.x - state.ship.speed);
            if (state.keys['d']) state.ship.x = Math.min(WIDTH - 30, state.ship.x + state.ship.speed);
            if (state.keys['w']) state.ship.y = Math.max(WATER_SURFACE + 10, state.ship.y - state.ship.vspeed);
            if (state.keys['s']) state.ship.y = Math.min(seafloorY[state.ship.x|0] - 30, state.ship.y + state.ship.vspeed);

            // Auto-pulse
            if (timestamp - state.lastPulseTime > 1000 / state.pulseRate) {
                const angle = Math.atan2(state.mouse.y - state.ship.y, state.mouse.x - state.ship.x);
                spawnPulse(state.ship.x, state.ship.y, angle, state.frequency, state.beamWidth);
                state.lastPulseTime = timestamp;
            }

            updatePulses(timestamp);

            // Render
            ctx.drawImage(bgCanvas, 0, 0);
            ctx.drawImage(mapCanvas, 0, 0);
            
            drawPulses(ctx);
            drawShip(ctx);

            ctx.strokeStyle = 'rgba(100, 200, 255, 0.5)'; ctx.lineWidth = 2;
            ctx.beginPath(); ctx.moveTo(0, WATER_SURFACE); ctx.lineTo(WIDTH, WATER_SURFACE); ctx.stroke();

            updateInfo();
            requestAnimationFrame(gameLoop);
        }

        requestAnimationFrame(gameLoop);
    </script>
</body>
</html>
